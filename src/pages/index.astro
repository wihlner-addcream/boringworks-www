---
import Container from "../components/Container.astro";
import CollapsibleSection from "../components/CollapsibleSection.astro";
import Cta from "../components/Cta.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Layout from "../components/Layout.astro";
import LinkButton from "../components/ui/LinkButton.astro";

const contactEmail = "hello@boringworks.se";

const process = [
  "Du skickar ett exempel på hur leads hanteras idag.",
  "Jag föreslår ett enkelt flöde.",
  "Du får ett fast pris.",
  "Jag bygger, testar och ser till att det fungerar.",
];

const boundaries = [
  "Jag bygger inte om hela ert CRM.",
  "Jag tar inte över er säljprocess.",
  "Jag erbjuder inte \"digital transformation\".",
  "Jag gör inte ett stort projekt av ett litet flöde.",
];
---

<Layout>
  <main>
    <Container>
      <section class="mx-auto max-w-4xl pb-16 pt-10 text-center lg:pb-20 lg:pt-16">
        <h1 class="mt-5 text-5xl font-bold leading-[0.95] tracking-tight text-zinc-950 sm:text-6xl lg:text-7xl">
          Sluta tappa bort leads
        </h1>
        <div class="mx-auto mt-7 max-w-2xl space-y-4 text-lg leading-8 text-zinc-700 sm:text-xl sm:leading-9">
          <p>
          När en ny förfrågan kommer in ska den inte fastna i någons inkorg.
          </p>
        </div>

        <div class="mx-auto mt-8 max-w-2xl rounded-lg border border-zinc-200 bg-white px-5 py-4 shadow-sm shadow-zinc-200/70">
          <p class="text-lg font-bold tracking-tight text-zinc-950 sm:text-xl">
            Från 2 500 kr i uppstart och 250 kr/mån.
          </p>
        </div>

        <div class="mt-8 flex justify-center">
          <LinkButton href={`mailto:${contactEmail}`}>Skicka ett exempel på ert flöde</LinkButton>
        </div>
      </section>



      <FeatureGrid />


      <CollapsibleSection
        id="sa-funkar-det"
        title="Ett tydligt flöde till ett fast pris"
        class="mt-24 max-w-4xl border-t border-zinc-200 pt-14"
      >
        <div class="mx-auto max-w-2xl space-y-3 text-left">
          {
            process.map((item, index) => (
              <div class="flex gap-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm shadow-zinc-200/60">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-zinc-950 text-sm font-semibold text-white">
                  {index + 1}
                </span>
                <p class="pt-0.5 text-lg leading-7 text-zinc-700">{item}</p>
              </div>
            ))
          }
        </div>
      </CollapsibleSection>


      <CollapsibleSection
        title="Vad jag inte gör"
        class="mt-24 border-t border-zinc-200 pt-14"
      >
        <div class="grid gap-2 text-left">
          {
            boundaries.map((item) => (
              <p class="rounded-md border border-zinc-200 bg-white px-4 py-3 font-semibold text-zinc-700">
                {item}
              </p>
            ))
          }
        </div>
      </CollapsibleSection>

      <Cta />

    </Container>
  </main>
</Layout>
