---
import "../styles/global.css";

const contactEmail = "hello@boringworks.se";

const workItems = [
  {
    label: "Software",
    title: "Small systems that hold up",
    body: "Websites, internal tools, and integrations built with plain edges and low operational weight.",
  },
  {
    label: "Operations",
    title: "The boring parts made reliable",
    body: "Deployment, hosting, maintenance, observability, and the practical details between idea and uptime.",
  },
  {
    label: "Care",
    title: "Steady improvements over noise",
    body: "Incremental fixes, migrations, and measured changes for systems that already have users.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Boring Works builds small, practical software and web systems."
    />
    <title>Boring Works</title>
  </head>
  <body class="min-h-screen bg-paper text-ink antialiased">
    <main>
      <section class="relative isolate min-h-[74svh] overflow-hidden">
        <picture class="absolute inset-0 -z-20">
          <source srcset="/images/workbench.webp" type="image/webp" />
          <img
            src="/images/workbench.png"
            alt=""
            class="h-full w-full object-cover object-center"
            width="1728"
            height="864"
            loading="eager"
            decoding="async"
          />
        </picture>
        <div class="absolute inset-0 -z-10 bg-paper/72"></div>

        <div
          class="mx-auto flex min-h-[74svh] w-full max-w-7xl flex-col justify-between px-5 py-5 sm:px-8 lg:px-10"
        >
          <header class="flex items-center justify-between gap-4 text-sm">
            <a
              href="/"
              class="font-medium tracking-[0.16em] text-ink uppercase"
              aria-label="Boring Works home"
            >
              boringworks.se
            </a>
            <a
              href={`mailto:${contactEmail}`}
              class="inline-flex min-h-10 items-center border border-ink/18 bg-paper/70 px-4 text-sm font-medium text-ink transition hover:border-olive hover:text-olive focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-olive"
            >
              Contact
            </a>
          </header>

          <div class="max-w-4xl pb-12 pt-28 sm:pb-16 lg:pb-20">
            <p
              class="mb-5 max-w-max border-l-2 border-clay pl-3 text-sm font-semibold tracking-[0.2em] text-steel uppercase"
            >
              Independent web and software work
            </p>
            <h1
              class="max-w-3xl text-6xl leading-[0.95] font-semibold tracking-normal text-balance sm:text-7xl lg:text-8xl"
            >
              Boring Works
            </h1>
            <p
              class="mt-7 max-w-2xl text-xl leading-8 text-ink/82 sm:text-2xl sm:leading-9"
            >
              Small, practical software for the parts of work that should just
              run.
            </p>
            <div class="mt-9 flex flex-wrap items-center gap-3">
              <a
                href={`mailto:${contactEmail}`}
                class="inline-flex min-h-12 items-center bg-ink px-5 text-base font-medium text-paper transition hover:bg-olive focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-olive"
              >
                Start a conversation
              </a>
              <a
                href="#work"
                class="inline-flex min-h-12 items-center border border-ink/20 px-5 text-base font-medium text-ink transition hover:border-olive hover:text-olive focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-olive"
              >
                What we do
              </a>
            </div>
          </div>
        </div>
      </section>

      <section id="work" class="bg-ink px-5 py-16 text-paper sm:px-8 lg:px-10">
        <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.85fr_1.4fr]">
          <div>
            <p class="text-sm font-semibold tracking-[0.2em] text-paper/50 uppercase">
              Work
            </p>
            <h2 class="mt-4 max-w-md text-3xl leading-tight font-semibold sm:text-4xl">
              Simple tools, maintained well.
            </h2>
          </div>

          <div class="grid gap-6 sm:grid-cols-3">
            {
              workItems.map((item) => (
                <article class="border-t border-paper/22 pt-5">
                  <p class="text-sm font-semibold text-clay">{item.label}</p>
                  <h3 class="mt-4 text-xl leading-snug font-semibold">
                    {item.title}
                  </h3>
                  <p class="mt-4 text-base leading-7 text-paper/70">
                    {item.body}
                  </p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="px-5 py-14 sm:px-8 lg:px-10">
        <div
          class="mx-auto flex max-w-7xl flex-col gap-6 border-t border-ink/14 pt-8 sm:flex-row sm:items-end sm:justify-between"
        >
          <div>
            <p class="text-sm font-semibold tracking-[0.2em] text-steel uppercase">
              Contact
            </p>
            <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">
              Bring the useful problem.
            </h2>
          </div>
          <a
            href={`mailto:${contactEmail}`}
            class="text-lg font-semibold text-olive underline decoration-olive/35 underline-offset-8 transition hover:text-clay hover:decoration-clay"
          >
            {contactEmail}
          </a>
        </div>
      </section>
    </main>

    <footer class="px-5 pb-8 text-sm text-steel sm:px-8 lg:px-10">
      <div class="mx-auto flex max-w-7xl justify-between gap-4">
        <p>&copy; {new Date().getFullYear()} Boring Works</p>
        <p>boringworks.se</p>
      </div>
    </footer>
  </body>
</html>
