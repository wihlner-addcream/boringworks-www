---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Not Found - Boring Works</title>
  </head>
  <body class="min-h-screen bg-paper text-ink antialiased">
    <main class="flex min-h-screen items-center px-5 py-16 sm:px-8 lg:px-10">
      <section class="mx-auto w-full max-w-3xl">
        <p class="text-sm font-semibold tracking-[0.2em] text-steel uppercase">
          404
        </p>
        <h1 class="mt-5 text-5xl leading-tight font-semibold sm:text-6xl">
          Page not found.
        </h1>
        <p class="mt-5 max-w-xl text-xl leading-8 text-ink/75">
          This address does not point at anything on boringworks.se.
        </p>
        <a
          href="/"
          class="mt-9 inline-flex min-h-12 items-center bg-ink px-5 text-base font-medium text-paper transition hover:bg-olive focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-olive"
        >
          Back home
        </a>
      </section>
    </main>
  </body>
</html>
