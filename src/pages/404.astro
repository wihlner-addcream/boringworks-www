---
import Container from "../components/Container.astro";
import Layout from "../components/Layout.astro";
import LinkButton from "../components/ui/LinkButton.astro";
---

<Layout title="Sidan hittades inte - Boring Works">
  <main class="py-24">
    <Container>
      <section class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold tracking-[0.18em] text-zinc-500 uppercase">
          404
        </p>
        <h1 class="mt-5 text-5xl font-bold tracking-tight text-zinc-950 sm:text-6xl">
          Sidan hittades inte.
        </h1>
        <p class="mt-5 text-xl leading-8 text-zinc-600">
          Den här adressen pekar inte på något på boringworks.se.
        </p>
        <div class="mt-8">
          <LinkButton href="/">Till startsidan</LinkButton>
        </div>
      </section>
    </Container>
  </main>
</Layout>
