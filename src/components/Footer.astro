    <div class="flex flex-col justify-between gap-3 text-sm text-zinc-500 sm:flex-row">
      <p>Boring Works gör små leadflöden svårare att tappa bort.</p>
      <p>&copy; {year} Boring Works</p>
    </div>
  </Container>
