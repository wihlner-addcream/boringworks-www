---
interface Props {
  id?: string;
  title: string;
  class?: string;
  contentClass?: string;
}

const {
  id,
  title,
  class: className,
  contentClass = "mt-8",
} = Astro.props;

const sectionId =
  id ??
  title
    .toLowerCase()
    .replaceAll("å", "a")
    .replaceAll("ä", "a")
    .replaceAll("ö", "o")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

const panelId = `${sectionId}-panel`;
---

<section
  id={sectionId}
  class:list={["mx-auto max-w-3xl text-center", className]}
  data-collapsible
>
  <h2 class="mt-3 text-4xl font-bold tracking-tight text-zinc-950 lg:text-5xl">
    <button
      class="group inline-flex max-w-full items-center justify-center gap-3 text-center transition hover:text-zinc-700 focus-visible:ring-2 focus-visible:ring-zinc-300 focus-visible:ring-offset-4 focus-visible:outline-none"
      type="button"
      aria-expanded="false"
      aria-controls={panelId}
      data-collapsible-trigger
    >
      <span>{title}</span>
      <span
        class="inline-block w-[0.7em] shrink-0 text-center font-bold leading-none text-zinc-950"
        aria-hidden="true"
        data-collapsible-icon
      >
        +
      </span>
    </button>
  </h2>

  <div
    id={panelId}
    class:list={["collapsible-panel", contentClass]}
    data-collapsible-state="closed"
    data-collapsible-panel
    style="max-height: 0px;"
  >
    <div data-collapsible-inner>
      <slot />
    </div>
  </div>
</section>
